# ══════════════════════════════════════════════════════════════════════
# LLM Security Testing Framework — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════

# ── OpenAI ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Anthropic ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Gemini ─────────────────────────────────────────────────────
GOOGLE_API_KEY=AIza...

# ── HuggingFace ───────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=hf_...

# ── PromptIntel ───────────────────────────────────────────────────────
PROMPTINTEL_API_KEY=...
PROMPTINTEL_ENDPOINT=https://...

# ── Ollama (local) ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Local GGUF Model ────────────────────────────────────────────────
# Path to your local GGUF model file (for local_gguf adapter type)
GGUF_MODEL_PATH=/path/to/your/model.gguf

# ── Client Testing ──────────────────────────────────────────────────
# Client's LLM/RAG API key (for security assessments)
CLIENT_API_KEY=
# Client's RAG endpoint URL (for RAG security testing)
CLIENT_RAG_ENDPOINT=https://client-rag.example.com/api/chat
# Judge model API key (used for evaluating client responses)
JUDGE_API_KEY=

# ── Gemini (alternative key name) ────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Framework settings ────────────────────────────────────────────────
# Target model for testing (overrides config YAML)
TARGET_MODEL=

# Judge model for evaluator (leave blank to use pattern-matching only)
JUDGE_MODEL=

# Max concurrent API calls
MAX_CONCURRENCY=5

# Output directory for reports
REPORTS_DIR=reports/

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
